# Master API key, in ACCOUNT_ID/KEY format. Required for grant/remove (admin
# only) and check (admin, delegated admin, or the user themselves).
TD_API_KEY=your_account_id/your_master_api_key

# Base URL of the Treasure Data REST API. Change region if needed, e.g.
# https://api.treasuredata.com (US), https://api.eu01.treasuredata.com (EU),
# https://api.treasuredata.co.jp (Tokyo).
TD_API_ENDPOINT=https://api.treasuredata.com

# API version to call: v3 or v4. Both behave identically.
TD_API_VERSION=v4
